<odoo>
  <record id="view_library_event_theme_list" model="ir.ui.view">
    <field name="name">library.event.theme.list</field>
    <field name="model">library.event.theme</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="code"/>
        <field name="css_class"/>
        <field name="use_for_events_page"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <record id="view_library_event_theme_form" model="ir.ui.view">
    <field name="name">library.event.theme.form</field>
    <field name="model">library.event.theme</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_apply_to_all_events"
                  type="object"
                  string="Apply to All Events"
                  class="btn-primary"/>
          <button name="action_clear_from_all_events"
                  type="object"
                  string="Clear From All Events"
                  class="btn-secondary"
                  invisible="event_count == 0"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_view_events"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-calendar">
              <field name="event_count" widget="statinfo" string="Events"/>
            </button>
          </div>
          <group>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="css_class"/>
            </group>
            <group>
              <field name="sequence"/>
              <field name="use_for_events_page"/>
              <field name="active"/>
            </group>
          </group>
          <group>
            <field name="description" nolabel="1" placeholder="Theme notes..."/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_library_event_theme" model="ir.actions.act_window">
    <field name="name">Library Event Themes</field>
    <field name="res_model">library.event.theme</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_library_event_themes"
            name="Library Themes"
            parent="event.event_main_menu"
            action="action_library_event_theme"
            sequence="100"/>
</odoo>
