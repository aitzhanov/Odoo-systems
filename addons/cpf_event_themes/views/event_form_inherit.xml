<odoo>
  <record id="view_event_form_theme_inherit" model="ir.ui.view">
    <field name="name">event.form.theme.inherit</field>
    <field name="model">event.event</field>
    <field name="inherit_id" ref="event.view_event_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='tag_ids']" position="after">
        <field name="theme_id" placeholder="Выбрать стиль..."/>
      </xpath>
    </field>
  </record>
</odoo>
