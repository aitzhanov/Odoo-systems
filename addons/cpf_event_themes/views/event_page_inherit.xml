<odoo>
  <!-- Detail page gets the active global theme -->
  <template id="event_details_theme" inherit_id="website_event.layout">
    <xpath expr="//div[@id='wrap']" position="attributes">
      <attribute name="t-attf-class">
        o_wevent_event js_event d-flex flex-column h-100
        #{'o_wevent_hide_sponsors' if hide_sponsors else ''}
        #{request.env['cpf.event.theme'].sudo().get_active_listing_theme_class()}
        cpf-event-detail-page
      </attribute>
    </xpath>
  </template>

  <!-- Listing page gets the active global theme -->
  <template id="event_listing_theme" inherit_id="website_event.index">
    <xpath expr="//div[@id='wrap']" position="attributes">
      <attribute name="t-attf-class">
        #{request.env['cpf.event.theme'].sudo().get_active_listing_theme_class()}
        cpf-events-listing-page
      </attribute>
    </xpath>
  </template>

  <!-- Hero section on top of Events page -->
  <template id="event_listing_hero" inherit_id="website_event.index">
    <xpath expr="//div[@id='wrap']/*[1]" position="before">
      <section t-attf-class="cpf-events-hero #{request.env['cpf.event.theme'].sudo().get_active_listing_theme_class()}">
        <div class="container">
          <div class="cpf-events-hero__inner">
            <div class="cpf-events-hero__kicker">Exhibitions and Events</div>
            <h1 class="cpf-events-hero__title">Events</h1>
            <div class="cpf-events-hero__subtitle">News and programming</div>
          </div>
        </div>
      </section>
    </xpath>
  </template>
</odoo>
