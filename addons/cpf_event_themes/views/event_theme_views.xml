<odoo>
  <record id="view_cpf_event_theme_list" model="ir.ui.view">
    <field name="name">cpf.event.theme.list</field>
    <field name="model">cpf.event.theme</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="css_class"/>
        <field name="is_listing_theme"/>
      </list>
    </field>
  </record>

  <record id="view_cpf_event_theme_form" model="ir.ui.view">
    <field name="name">cpf.event.theme.form</field>
    <field name="model">cpf.event.theme</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="css_class"/>
            <field name="preview_color"/>
            <field name="is_listing_theme"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cpf_event_theme" model="ir.actions.act_window">
    <field name="name">Event Themes</field>
    <field name="res_model">cpf.event.theme</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_cpf_themes"
            name="Themes"
            parent="event.event_main_menu"
            action="action_cpf_event_theme"
            sequence="99"/>
</odoo>
