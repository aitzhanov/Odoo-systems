<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_news_post" model="ir.actions.act_window">
        <field name="name">News</field>
        <field name="res_model">news.post</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_news_post_list" model="ir.ui.view">
        <field name="name">news.post.list</field>
        <field name="model">news.post</field>
        <field name="arch" type="xml">
            <list string="News Posts">
                <field name="name"/>
                <field name="date"/>
                <field name="is_published" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_news_post_form" model="ir.ui.view">
        <field name="name">news.post.form</field>
        <field name="model">news.post</field>
        <field name="arch" type="xml">
            <form string="News Post">
                <header>
                    <button name="website_publish_button"
                            type="object"
                            string="Publish"
                            class="btn-primary"
                            invisible="is_published"/>
                    <button name="website_publish_button"
                            type="object"
                            string="Unpublish"
                            class="btn-secondary"
                            invisible="not is_published"/>
                    <!-- Toggle Published/Unpublished — как в Events -->
                    <field name="is_published"
                           widget="boolean_toggle"
                           nolabel="1"
                           options="{'terminology': 'archive'}"/>
                </header>
                <sheet>
                    <!-- Лента Published/Unpublished в углу -->
                    <widget name="web_ribbon"
                            title="Published"
                            bg_color="text-bg-success"
                            invisible="not is_published"/>
                    <widget name="web_ribbon"
                            title="Unpublished"
                            bg_color="text-bg-danger"
                            invisible="is_published"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="News Title..."
                                   required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="date"/>
                            <field name="is_published" invisible="1"/>
                        </group>
                        <group>
                            <div class="d-flex align-items-center" style="padding: 4px 0;">
                                <button type="object"
                                        name="open_website_url"
                                        string="Открыть на сайте"
                                        class="btn btn-secondary"
                                        icon="fa-globe"/>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="Content">
                            <field name="content" widget="html"/>
                        </page>
                        <page string="Images">
                            <field name="image_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="image" widget="image"
                                           options="{'size': [90, 90]}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Настройки галереи">
                            <group string="Расположение">
                                <field name="gallery_layout" widget="radio"/>
                            </group>

                            <group string="Режим: Основное + справа" invisible="gallery_layout == 'bottom'">
                                <field name="main_image_width"
                                    string="Ширина основного фото (%)"
                                    help="От 50 до 90. Миниатюры займут оставшееся место."/>
                                <div colspan="2" class="text-muted small" style="padding: 4px 8px;">
                                    💡 Ширина миниатюр = 100% - ширина основного
                                </div>
                            </group>

                            <group string="Режим: Основное + снизу" invisible="gallery_layout == 'side'">
                                <field name="main_image_height"
                                    string="Высота основного фото (px)"/>
                                <field name="thumb_height"
                                    string="Высота миниатюр (px)"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_news_post_search" model="ir.ui.view">
        <field name="name">news.post.search</field>
        <field name="model">news.post</field>
        <field name="arch" type="xml">
            <search string="Search News">
                <field name="name"/>
                <filter name="published" string="Published"
                        domain="[('is_published','=',True)]"/>
                <filter name="unpublished" string="Unpublished"
                        domain="[('is_published','=',False)]"/>
            </search>
        </field>
    </record>

</odoo>